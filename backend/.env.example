# Copia este archivo a backend/.env y completa con tus credenciales reales.
# NO subas .env a git (ya está en .gitignore).

# --- Seguridad ---
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-larga
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de datos MySQL ---
DB_NAME=cloudtasks
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_HOST=127.0.0.1
DB_PORT=3306
